diff --git a/bench/modexp.cc b/bench/modexp.cc
new file mode 100644
index 0000000000..ed8d99ad3a
--- /dev/null
+++ b/bench/modexp.cc
@@ -0,0 +1,367 @@
+// Copied from the same benchmark in BoringSSL
+#include <benchmark/benchmark.h>
+
+#include <openssl/bn.h>
+#include <openssl/rsa.h>
+
+// Generate a random BIGNUM of specified bit size
+static BIGNUM *generate_random_bn(int bits) {
+  BIGNUM *bn = BN_new();
+  if (!bn) {
+    return NULL;
+  }
+
+  if (!BN_rand(bn, bits, BN_RAND_TOP_ANY, BN_RAND_BOTTOM_ANY)) {
+    BN_free(bn);
+    return NULL;
+  }
+
+  return bn;
+}
+
+// Generate a random modulus (prime number) suitable for Montgomery
+static BIGNUM *generate_random_prime(int bits) {
+  BIGNUM *prime = BN_new();
+  if (!prime) {
+    return NULL;
+  }
+
+  if (!BN_generate_prime_ex(prime, bits, 0, NULL, NULL, NULL)) {
+    BN_free(prime);
+    return NULL;
+  }
+
+  return prime;
+}
+
+// Create Montgomery context for a modulus
+static BN_MONT_CTX *create_montgomery_ctx(BIGNUM *mod, BN_CTX *ctx) {
+  BN_MONT_CTX *mont = BN_MONT_CTX_new();
+  if (!mont) {
+    return NULL;
+  }
+
+  if (!BN_MONT_CTX_set(mont, mod, ctx)) {
+    BN_MONT_CTX_free(mont);
+    return NULL;
+  }
+
+  return mont;
+}
+
+static void BM_OSSLModMulMontgomery(benchmark::State &state) {
+  int bits = state.range(0);
+  BN_CTX *ctx = BN_CTX_new();
+  BIGNUM *mod = generate_random_prime(bits);
+  BIGNUM *a = generate_random_bn(bits);
+  BIGNUM *b = generate_random_bn(bits);
+  
+  // Create Montgomery context
+  BN_MONT_CTX *mont = create_montgomery_ctx(mod, ctx);
+
+  if (!mont) {
+    BN_free(mod);
+    BN_free(a);
+    BN_free(b);
+    BN_CTX_free(ctx);
+    fprintf(stderr, "Failed to create Montgomery context\n");
+    abort();
+  }
+
+  // Ensure inputs are less than modulus
+  if (BN_cmp(a, mod) >= 0) {
+    BN_mod(a, a, mod, ctx);
+  }
+  if (BN_cmp(b, mod) >= 0) {
+    BN_mod(b, b, mod, ctx);
+  }
+
+  // Convert inputs to Montgomery form
+  BIGNUM *a_mont = BN_new();
+  BIGNUM *b_mont = BN_new();
+  BIGNUM *result = BN_new();
+  
+  if (!a_mont || !b_mont || !result) {
+    BN_free(a_mont);
+    BN_free(b_mont);
+    BN_free(result);
+    BN_free(mod);
+    BN_free(a);
+    BN_free(b);
+    BN_MONT_CTX_free(mont);
+    BN_CTX_free(ctx);
+    return;
+  }
+
+  BN_to_montgomery(a_mont, a, mont, ctx);
+  BN_to_montgomery(b_mont, b, mont, ctx);
+
+  for (auto _ : state) {
+    BN_mod_mul_montgomery(result, a_mont, b_mont, mont, ctx);
+    benchmark::DoNotOptimize(result);
+  }
+
+  BN_free(a_mont);
+  BN_free(b_mont);
+  BN_free(result);
+  BN_free(mod);
+  BN_free(a);
+  BN_free(b);
+  BN_MONT_CTX_free(mont);
+  BN_CTX_free(ctx);
+}
+
+static void BM_OSSLModExpConsttime(benchmark::State &state) {
+  int bits = state.range(0);
+  BN_CTX *ctx = BN_CTX_new();
+  BIGNUM *mod = generate_random_prime(bits);
+  BIGNUM *base = generate_random_bn(bits);
+  BIGNUM *exp = generate_random_bn(bits);
+  BN_MONT_CTX *mont = create_montgomery_ctx(mod, ctx);
+
+  if (!mont) {
+    BN_free(mod);
+    BN_free(base);
+    BN_free(exp);
+    BN_CTX_free(ctx);
+    fprintf(stderr, "Failed to create Montgomery context\n");
+    abort();
+  }
+
+  // Ensure base < modulus
+  if (BN_cmp(base, mod) >= 0) {
+      BN_mod(base, base, mod, ctx);
+  }
+
+  BIGNUM *result = BN_new();
+  if (!result) {
+    BN_free(mod);
+    BN_free(base);
+    BN_free(exp);
+    BN_CTX_free(ctx);
+    fprintf(stderr, "Failed to create result BIGNUM\n");
+    abort();
+  }
+
+  for (auto _ : state) {
+    BN_mod_exp_mont_consttime(result, base, exp, mod, ctx, mont);
+  }
+
+  BN_free(mod);
+  BN_free(base);
+  BN_free(exp);
+  BN_MONT_CTX_free(mont);
+  BN_CTX_free(ctx);
+}
+
+static void BM_OSSLModExpRSAE(benchmark::State &state) {
+  int bits = state.range(0);
+  BN_CTX *ctx = BN_CTX_new();
+  BIGNUM *mod = generate_random_prime(bits);
+  BIGNUM *base = generate_random_bn(bits);
+  BIGNUM *exp = BN_new();
+  BN_set_word(exp, 65537);
+  BN_MONT_CTX *mont = create_montgomery_ctx(mod, ctx);
+
+  if (!mont) {
+    BN_free(mod);
+    BN_free(base);
+    BN_free(exp);
+    BN_CTX_free(ctx);
+    fprintf(stderr, "Failed to create Montgomery context\n");
+    abort();
+  }
+
+  // Ensure base < modulus
+  if (BN_cmp(base, mod) >= 0) {
+      BN_mod(base, base, mod, ctx);
+  }
+
+  BIGNUM *result = BN_new();
+  if (!result) {
+    BN_free(mod);
+    BN_free(base);
+    BN_free(exp);
+    BN_CTX_free(ctx);
+    fprintf(stderr, "Failed to create result BIGNUM\n");
+    abort();
+  }
+
+  for (auto _ : state) {
+    BN_mod_exp_mont(result, base, exp, mod, ctx, mont);
+    benchmark::DoNotOptimize(result);
+  }
+
+  BN_free(mod);
+  BN_free(base);
+  BN_free(exp);
+  BN_MONT_CTX_free(mont);
+  BN_CTX_free(ctx);
+}
+
+static void BM_OSSLModExpConsttime_x2(benchmark::State &state) {
+  int bits = state.range(0);
+  BN_CTX *ctx = BN_CTX_new();
+  BIGNUM *mod1 = generate_random_prime(bits);
+  BIGNUM *base1 = generate_random_bn(bits);
+  BIGNUM *exp1 = generate_random_bn(bits);
+  BN_MONT_CTX *mont1 = create_montgomery_ctx(mod1, ctx);
+  BIGNUM *mod2 = generate_random_prime(bits);
+  BIGNUM *base2 = generate_random_bn(bits);
+  BIGNUM *exp2 = generate_random_bn(bits);
+  BN_MONT_CTX *mont2 = create_montgomery_ctx(mod2, ctx);
+
+  if (!mont1 || !mont2) {
+    BN_free(mod1);
+    BN_free(base1);
+    BN_free(exp1);
+    BN_free(mod2);
+    BN_free(base2);
+    BN_free(exp2);
+    BN_CTX_free(ctx);
+    fprintf(stderr, "Failed to create Montgomery context\n");
+    abort();
+  }
+
+  // Ensure base < modulus
+  if (BN_cmp(base1, mod1) >= 0) {
+      BN_mod(base1, base1, mod1, ctx);
+  }
+  if (BN_cmp(base2, mod2) >= 0) {
+      BN_mod(base2, base2, mod2, ctx);
+  }
+
+  BIGNUM *result1 = BN_new();
+  BIGNUM *result2 = BN_new();
+  if (!result1 || !result2) {
+    BN_free(mod1);
+    BN_free(base1);
+    BN_free(exp1);
+    BN_free(mod2);
+    BN_free(base2);
+    BN_free(exp2);
+    BN_CTX_free(ctx);
+    fprintf(stderr, "Failed to create result BIGNUMs\n");
+    abort();
+  }
+
+  for (auto _ : state) {
+    BN_mod_exp_mont_consttime_x2(result1, base1, exp1, mod1, mont1, result2, base2, exp2, mod2, mont2, ctx);
+    benchmark::DoNotOptimize(result1);
+    benchmark::DoNotOptimize(result2);
+  }
+
+  BN_free(mod1);
+  BN_free(mod2);
+  BN_free(base1);
+  BN_free(base2);
+  BN_free(exp1);
+  BN_free(exp2);
+  BN_MONT_CTX_free(mont1);
+  BN_MONT_CTX_free(mont2);
+  BN_CTX_free(ctx);
+}
+
+static void BM_OSSLRSAModExpCRT(benchmark::State &state) {
+  int bits = state.range(0);
+  BN_CTX *ctx = BN_CTX_new();
+  if (!ctx) {
+    fprintf(stderr, "Failed to create BN_CTX\n");
+    abort();
+  }
+
+  // Generate RSA key with all components
+  RSA *rsa = RSA_new();
+  if (!rsa) {
+    BN_CTX_free(ctx);
+    fprintf(stderr, "Failed to create RSA structure\n");
+    abort();
+  }
+
+  // Set the method to use OpenSSL's rsa_ossl_mod_exp
+  if (!RSA_set_method(rsa, RSA_PKCS1_OpenSSL())) {
+    RSA_free(rsa);
+    BN_CTX_free(ctx);
+    fprintf(stderr, "Failed to set RSA method\n");
+    abort();
+  }
+
+  // Generate public exponent (65537)
+  BIGNUM *e = BN_new();
+  if (!e || !BN_set_word(e, RSA_F4)) {
+    BN_free(e);
+    RSA_free(rsa);
+    BN_CTX_free(ctx);
+    fprintf(stderr, "Failed to create public exponent\n");
+    abort();
+  }
+
+  // Generate RSA key
+  if (!RSA_generate_key_ex(rsa, bits, e, NULL)) {
+    BN_free(e);
+    RSA_free(rsa);
+    BN_CTX_free(ctx);
+    fprintf(stderr, "Failed to generate RSA key\n");
+    abort();
+  }
+
+  BN_free(e);
+
+  // Enable caching of private key Montgomery contexts
+  RSA_set_flags(rsa, RSA_FLAG_CACHE_PRIVATE);
+
+  // Get modulus n
+  const BIGNUM *n = RSA_get0_n(rsa);
+  if (!n) {
+    RSA_free(rsa);
+    BN_CTX_free(ctx);
+    fprintf(stderr, "Failed to get modulus\n");
+    abort();
+  }
+
+  // Generate random input (must be less than modulus n)
+  BIGNUM *input = BN_new();
+  if (!input) {
+    RSA_free(rsa);
+    BN_CTX_free(ctx);
+    fprintf(stderr, "Failed to create input BIGNUM\n");
+    abort();
+  }
+
+  // Generate random number less than n
+  if (!BN_rand_range(input, n)) {
+    BN_free(input);
+    RSA_free(rsa);
+    BN_CTX_free(ctx);
+    fprintf(stderr, "Failed to generate random input\n");
+    abort();
+  }
+
+  BIGNUM *result = BN_new();
+  if (!result) {
+    BN_free(input);
+    RSA_free(rsa);
+    BN_CTX_free(ctx);
+    fprintf(stderr, "Failed to create result BIGNUM\n");
+    abort();
+  }
+
+  for (auto _ : state) {
+    if (!rsa_ossl_mod_exp(result, input, rsa, ctx)) {
+      state.SkipWithError("rsa_ossl_mod_exp failed");
+      break;
+    }
+    benchmark::DoNotOptimize(result);
+  }
+
+  BN_free(input);
+  BN_free(result);
+  RSA_free(rsa);
+  BN_CTX_free(ctx);
+}
+
+BENCHMARK(BM_OSSLModMulMontgomery)->DenseRange(64, 4096, 64)->Unit(benchmark::kNanosecond);
+BENCHMARK(BM_OSSLModExpConsttime)->Arg(1024)->Arg(1536)->Arg(2048)->Arg(3072)->Arg(4096)->Unit(benchmark::kMicrosecond);
+BENCHMARK(BM_OSSLModExpRSAE)->Arg(1024)->Arg(1536)->Arg(2048)->Arg(3072)->Arg(4096)->Unit(benchmark::kMicrosecond);
+BENCHMARK(BM_OSSLModExpConsttime_x2)->Arg(1024)->Arg(1536)->Arg(2048)->Arg(3072)->Arg(4096)->Unit(benchmark::kMicrosecond);
+BENCHMARK(BM_OSSLRSAModExpCRT)->Arg(2048)->Arg(3072)->Arg(4096)->Unit(benchmark::kMicrosecond);
