new file mode 100644
index 0000000000..ab9b7ce206
--- /dev/null
+++ b/bench/CMakeLists.txt
@@ -0,0 +1,51 @@
+cmake_minimum_required(VERSION 3.10)
+project(openssl_bench)
+
+set(CMAKE_CXX_STANDARD 17)
+set(CMAKE_CXX_STANDARD_REQUIRED ON)
+set(CMAKE_EXE_LINKER_FLAGS "-no-pie")
+
+# Must use custom OpenSSL path at ../openssl
+# Build it by running ./build_openssl.sh in the repository root
+set(OPENSSL_ROOT_DIR "${CMAKE_CURRENT_SOURCE_DIR}/../openssl")
+message(STATUS "Using custom OpenSSL path at: ${OPENSSL_ROOT_DIR} (be sure to run ./build_openssl.sh in the repository root)")
+
+find_package(OpenSSL REQUIRED)
+find_package(benchmark REQUIRED)
+
+# Add combined benchmark executable
+add_executable(bench modexp.cc rsa.cc amm.cc)
+
+add_executable(test test.cc)
+
+# Link libraries
+target_link_libraries(test
+    PRIVATE
+    OpenSSL::SSL
+    OpenSSL::Crypto
+    benchmark::benchmark
+    benchmark::benchmark_main
+)
+
+target_link_libraries(bench
+    PRIVATE
+    OpenSSL::SSL
+    OpenSSL::Crypto
+    benchmark::benchmark
+    benchmark::benchmark_main
+)
+
+# Include directories
+target_include_directories(bench
+    PRIVATE
+    ${OPENSSL_INCLUDE_DIR}
+)
+
+# Compiler flags
+target_compile_options(bench
+    PRIVATE
+    -Wall
+    -Wextra
+    -O3
+    -g
+)
